---
import { getLocale, localePath } from "../i18n/config";
import { useCopy } from "../i18n/copy";
import { getProjects } from "../i18n/content";

const locale = getLocale(Astro.currentLocale);
const t = useCopy(locale).cmdk;
const projects = getProjects(locale);
---

<div class="cmdk-overlay" id="cmdk" role="dialog" aria-modal="true" aria-label="Command palette">
  <div class="cmdk-panel">
    <input
      class="cmdk-input"
      id="cmdk-input"
      placeholder={t.placeholder}
      autocomplete="off"
      spellcheck="false"
    />
    <div class="cmdk-list" id="cmdk-list">
      <div class="cmdk-group-label">{t.pages}</div>
      <a href={localePath(locale, "/")} class="cmdk-item" data-keywords="home start inicio"><span>↗</span> {t.home} <span class="meta">G H</span></a>
      <a href={localePath(locale, "/work")} class="cmdk-item" data-keywords="projects portfolio projetos"><span>↗</span> {t.work} <span class="meta">G W</span></a>
      <a href={localePath(locale, "/about")} class="cmdk-item" data-keywords="about bio sobre"><span>↗</span> {t.about} <span class="meta">G A</span></a>
      <a href={localePath(locale, "/contact")} class="cmdk-item" data-keywords="email reach contato"><span>↗</span> {t.contact} <span class="meta">G C</span></a>

      <div class="cmdk-group-label">{t.projects}</div>
      {projects.map((p) => (
        <a
          href={localePath(locale, `/work/${p.slug}`)}
          class="cmdk-item"
          data-keywords={`${p.title} ${p.client} ${p.type}`}
        >
          <span class="font-mono text-[10px] text-[var(--color-fg-subtle)]">{p.number}</span>
          {p.title}
          <span class="meta">{p.client}</span>
        </a>
      ))}

      <div class="cmdk-group-label">{t.actions}</div>
      <button class="cmdk-item" data-action="theme" data-keywords="dark light theme toggle tema">
        <span>◐</span> {t.toggleTheme} <span class="meta">⌘ J</span>
      </button>
      <a href="mailto:gabriel@oliveibriel.com" class="cmdk-item" data-keywords="email">
        <span>✉</span> {t.sendEmail} <span class="meta">⌘ M</span>
      </a>
      <a href="https://www.linkedin.com/in/oliveibriel" target="_blank" rel="noopener noreferrer" class="cmdk-item" data-keywords="linkedin">
        <span>↗</span> LinkedIn
      </a>
    </div>
  </div>
</div>

<script>
  function setupCmdk() {
    const overlay = document.getElementById("cmdk") as HTMLDivElement | null;
    const input = document.getElementById("cmdk-input") as HTMLInputElement | null;
    const list = document.getElementById("cmdk-list");
    if (!overlay || !input || !list) return;
    if ((overlay as any).dataset.bound === "true") return;
    (overlay as any).dataset.bound = "true";

    const items = Array.from(list.querySelectorAll<HTMLElement>(".cmdk-item, .cmdk-group-label"));

    const open = () => {
      overlay.classList.add("open");
      setTimeout(() => input.focus(), 50);
    };
    const close = () => {
      overlay.classList.remove("open");
      input.value = "";
      filter("");
    };

    const filter = (q: string) => {
      const norm = q.trim().toLowerCase();
      let lastGroupVisible = false;
      let pendingGroup: HTMLElement | null = null;
      let groupHasItems = false;

      items.forEach((el) => {
        if (el.classList.contains("cmdk-group-label")) {
          if (pendingGroup) {
            pendingGroup.style.display = groupHasItems ? "" : "none";
          }
          pendingGroup = el;
          groupHasItems = false;
          return;
        }
        const text = (el.textContent || "").toLowerCase();
        const kw = (el.getAttribute("data-keywords") || "").toLowerCase();
        const match = !norm || text.includes(norm) || kw.includes(norm);
        el.style.display = match ? "" : "none";
        if (match) groupHasItems = true;
      });
      if (pendingGroup) {
        (pendingGroup as HTMLElement).style.display = groupHasItems ? "" : "none";
      }
    };

    input.addEventListener("input", (e) => {
      filter((e.target as HTMLInputElement).value);
    });

    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) close();
    });

    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        if (overlay.classList.contains("open")) close();
        else open();
        return;
      }
      if (e.key === "Escape" && overlay.classList.contains("open")) {
        close();
      }
      if ((e.metaKey || e.ctrlKey) && e.key === "j") {
        e.preventDefault();
        document.getElementById("theme-toggle")?.click();
      }
    });

    list.querySelectorAll<HTMLElement>(".cmdk-item[data-action='theme']").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        close();
        document.getElementById("theme-toggle")?.click();
      });
    });

    list.querySelectorAll<HTMLAnchorElement>("a.cmdk-item").forEach((a) => {
      a.addEventListener("click", () => close());
    });
  }

  setupCmdk();
  document.addEventListener("astro:after-swap", setupCmdk);
</script>
