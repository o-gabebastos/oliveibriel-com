---
import { getLocale, barePath, localePath } from "../i18n/config";
import { useCopy } from "../i18n/copy";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
}

const locale = getLocale(Astro.currentLocale);
const t = useCopy(locale);

const {
  title = t.seo.homeTitle,
  description = t.seo.homeDescription,
  image = "/gabriel-oliveira.jpg",
  type = "website",
} = Astro.props;

const siteUrl = "https://oliveibriel.com";
const base = Astro.site ?? siteUrl;
const canonicalURL = new URL(Astro.url.pathname, base).toString();
const ogImage = new URL(image, base).toString();

// hreflang alternates: same content path in each locale.
const bare = barePath(Astro.url.pathname);
const enURL = new URL(bare, base).toString();
const ptURL = new URL(localePath("pt", bare), base).toString();
const ogLocale = locale === "pt" ? "pt_BR" : "en_US";
const ogLocaleAlt = locale === "pt" ? "en_US" : "pt_BR";

const jsonLdDescription =
  locale === "pt"
    ? "Product designer sênior especializado em SaaS industrial, design systems e ferramentas com IA. 7+ anos de experiência."
    : "Senior Product Designer specializing in industrial SaaS, design systems, and AI-native tools. 7+ years of experience.";
const jobTitle = locale === "pt" ? "Product Designer Sênior" : "Senior Product Designer";

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Gabriel Oliveira",
  jobTitle,
  description: jsonLdDescription,
  url: siteUrl,
  email: "mailto:gabriel@oliveibriel.com",
  image: `${siteUrl}/gabriel-oliveira.jpg`,
  sameAs: ["https://www.linkedin.com/in/oliveibriel"],
  worksFor: [
    {
      "@type": "Organization",
      name: "Techco.lab",
      description: "NETZSCH's innovation hub",
      parentOrganization: { "@type": "Organization", name: "NETZSCH" },
    },
  ],
  address: {
    "@type": "PostalAddress",
    addressLocality: "Curitiba",
    addressCountry: "BR",
  },
  knowsAbout: [
    "Product Design",
    "Design Systems",
    "Industrial UX",
    "B2B SaaS",
    "AI-native tools",
    "UX Strategy",
    "Information Architecture",
    "Accessibility",
  ],
};
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content="Gabriel Oliveira" />
<link rel="canonical" href={canonicalURL} />

<link rel="alternate" hreflang="en" href={enURL} />
<link rel="alternate" hreflang="pt-BR" href={ptURL} />
<link rel="alternate" hreflang="x-default" href={enURL} />

<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content="Gabriel Oliveira" />
<meta property="og:locale" content={ogLocale} />
<meta property="og:locale:alternate" content={ogLocaleAlt} />
{type === "article" && (
  <meta property="article:author" content="Gabriel Oliveira" />
)}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<meta name="theme-color" content="#0a0e14" media="(prefers-color-scheme: dark)" />
<meta name="theme-color" content="#f4f4f5" media="(prefers-color-scheme: light)" />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="alternate" type="application/rss+xml" title="Gabriel Oliveira" href="/rss.xml" />

<script type="application/ld+json" is:inline set:html={JSON.stringify(personJsonLd)} />
