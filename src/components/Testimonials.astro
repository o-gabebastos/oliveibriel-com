---
import { testimonials as all } from "../data/testimonials";

interface Props {
  limit?: number;
  heading?: string;
  blurb?: string;
}

const {
  limit,
  heading = "In their words.",
  blurb = "Recommendations from LinkedIn: designers, engineers, and clients I've worked with.",
} = Astro.props;

const items = typeof limit === "number" ? all.slice(0, limit) : all;
const total = items.length;
const pad = (n: number) => String(n).padStart(2, "0");

// Server-render the initial coverflow positions (active = 0) so there's no
// flash of stacked cards before the client script runs, and it degrades
// gracefully if JS never loads.
const half = Math.floor(total / 2);
const initClass = (i: number) => {
  let d = i;
  if (d > half) d -= total;
  if (d < -half) d += total;
  if (d === 0) return "is-center";
  if (d === -1) return "is-left";
  if (d === 1) return "is-right";
  return d < 0 ? "is-far-left" : "is-far-right";
};
---

<section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-16 md:py-20 border-t border-[var(--color-border)]">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10 md:mb-12" data-reveal>
    <div>
      <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-accent)]">
        Testimonials
      </span>
      <h2 class="mt-2 text-2xl md:text-4xl font-extrabold display" style="letter-spacing:-0.035em;">
        {heading}
      </h2>
    </div>
    <p class="text-sm md:text-[15px] text-[var(--color-fg-muted)] leading-relaxed max-w-sm md:text-right">
      {blurb}
    </p>
  </div>

  {total <= 1 ? (
    items.map((t) => (
      <figure class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-6 md:p-8 max-w-xl mx-auto">
        <blockquote class="text-[15px] md:text-base leading-relaxed text-[var(--color-fg)]">{t.quote}</blockquote>
        <figcaption class="mt-5 pt-4 border-t border-[var(--color-border)]">
          <div class="font-semibold text-[var(--color-fg)] text-[15px]">{t.name}</div>
          <div class="font-mono text-[11px] uppercase tracking-wider text-[var(--color-fg-subtle)] mt-1">
            {t.role}{t.relation ? ` · ${t.relation}` : ""}
          </div>
        </figcaption>
      </figure>
    ))
  ) : (
    <div
      data-carousel
      class="relative"
      role="region"
      aria-roledescription="carousel"
      aria-label="Testimonials"
      data-reveal
    >
      <div class="tglow" aria-hidden="true"></div>

      <div data-viewport class="tviewport relative z-10 overflow-hidden" style="--card-w: min(88vw, 30rem);">
        {items.map((t, i) => (
          <figure
            data-slide
            data-index={i}
            class={`tcard ${initClass(i)}`}
            role="group"
            aria-roledescription="slide"
            aria-label={`${i + 1} of ${total}`}
            aria-hidden={i === 0 ? "false" : "true"}
          >
            <svg class="size-6 text-[var(--color-accent)] opacity-40 mb-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M9.5 6C6.5 6 4 8.5 4 11.5V18h6v-6H7c0-1.7 1.1-3 2.5-3V6Zm10 0c-3 0-5.5 2.5-5.5 5.5V18h6v-6h-3c0-1.7 1.1-3 2.5-3V6Z" />
            </svg>
            <blockquote class="text-[15px] md:text-base leading-relaxed text-[var(--color-fg)]">
              {t.quote}
            </blockquote>
            <figcaption class="mt-5 pt-4 border-t border-[var(--color-border)]">
              <div class="font-semibold text-[var(--color-fg)] text-[15px]">{t.name}</div>
              <div class="font-mono text-[11px] uppercase tracking-wider text-[var(--color-fg-subtle)] mt-1">
                {t.role}{t.relation ? ` · ${t.relation}` : ""}
              </div>
              {t.translated && (
                <div class="font-mono text-[10px] text-[var(--color-fg-subtle)] opacity-70 mt-1.5">
                  Translated from Portuguese
                </div>
              )}
            </figcaption>
          </figure>
        ))}
      </div>

      <!-- Controls -->
      <div class="relative z-10 mt-6 flex items-center justify-between gap-6">
        <div class="flex items-center gap-2">
          <button
            data-prev
            type="button"
            aria-label="Previous testimonial"
            class="grid place-items-center size-10 rounded-full border border-[var(--color-border-strong)] text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:border-[var(--color-fg)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)] transition-colors"
          >
            <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6" /></svg>
          </button>
          <button
            data-next
            type="button"
            aria-label="Next testimonial"
            class="grid place-items-center size-10 rounded-full border border-[var(--color-border-strong)] text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:border-[var(--color-fg)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)] transition-colors"
          >
            <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6" /></svg>
          </button>
        </div>

        <div class="flex items-center gap-4">
          <div data-dots class="flex items-center gap-1.5" role="tablist" aria-label="Choose testimonial">
            {items.map((_, i) => (
              <button
                data-dot
                type="button"
                role="tab"
                aria-label={`Go to testimonial ${i + 1}`}
                aria-selected={i === 0 ? "true" : "false"}
                class="h-1.5 rounded-full transition-all duration-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
              ></button>
            ))}
          </div>
          <span data-counter class="font-mono text-[11px] tracking-wider text-[var(--color-fg-subtle)] tabular-nums">
            {pad(1)} / {pad(total)}
          </span>
        </div>
      </div>
    </div>
  )}
</section>

<style>
  .tviewport {
    min-height: 22rem;
  }

  .tglow {
    position: absolute;
    inset: 6% 14%;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(58% 58% at 30% 42%, color-mix(in oklab, var(--color-accent) 20%, transparent), transparent 70%),
      radial-gradient(46% 46% at 74% 60%, color-mix(in oklab, var(--color-accent) 14%, transparent), transparent 70%);
    filter: blur(44px);
    opacity: 0.55;
  }

  .tcard {
    position: absolute;
    top: 50%;
    left: 50%;
    width: var(--card-w);
    padding: 1.5rem;
    border-radius: 1.5rem;
    /* Apple-style liquid glass: translucent fill, frosted backdrop, specular edge. */
    background: linear-gradient(
      155deg,
      color-mix(in oklab, white 80%, transparent),
      color-mix(in oklab, white 46%, transparent)
    );
    border: 1px solid color-mix(in oklab, white 72%, transparent);
    box-shadow:
      0 12px 36px -10px rgba(9, 9, 11, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.78);
    -webkit-backdrop-filter: blur(18px) saturate(1.4);
    backdrop-filter: blur(18px) saturate(1.4);
    transform: translate(-50%, -50%);
    transform-origin: center;
    will-change: transform, opacity, filter;
    transition:
      transform 600ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 600ms cubic-bezier(0.16, 1, 0.3, 1),
      filter 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  @media (min-width: 768px) {
    .tcard { padding: 2rem; }
  }

  .tcard.is-center {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
    z-index: 30;
    filter: none;
  }
  .tcard.is-left {
    transform: translate(calc(-50% - 72%), -50%) scale(0.8);
    opacity: 0.55;
    z-index: 20;
    filter: blur(3px);
    cursor: pointer;
  }
  .tcard.is-right {
    transform: translate(calc(-50% + 72%), -50%) scale(0.8);
    opacity: 0.55;
    z-index: 20;
    filter: blur(3px);
    cursor: pointer;
  }
  .tcard.is-far-left {
    transform: translate(calc(-50% - 128%), -50%) scale(0.68);
    opacity: 0;
    z-index: 10;
    filter: blur(6px);
    pointer-events: none;
  }
  .tcard.is-far-right {
    transform: translate(calc(-50% + 128%), -50%) scale(0.68);
    opacity: 0;
    z-index: 10;
    filter: blur(6px);
    pointer-events: none;
  }

  @media (max-width: 640px) {
    .tcard.is-left,
    .tcard.is-right { opacity: 0.28; }
  }

  @media (prefers-reduced-motion: reduce) {
    .tcard { transition: none; }
  }
</style>

<script>
  const AUTOPLAY_MS = 6000;
  const SWIPE_THRESHOLD = 40;
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  function initCarousel(root: HTMLElement) {
    const viewport = root.querySelector<HTMLElement>("[data-viewport]");
    const slides = Array.from(root.querySelectorAll<HTMLElement>("[data-slide]"));
    const dots = Array.from(root.querySelectorAll<HTMLElement>("[data-dot]"));
    const counter = root.querySelector<HTMLElement>("[data-counter]");
    const prevBtn = root.querySelector<HTMLElement>("[data-prev]");
    const nextBtn = root.querySelector<HTMLElement>("[data-next]");
    if (!viewport || slides.length < 2) return;

    const total = slides.length;
    const half = Math.floor(total / 2);
    const pad = (n: number) => String(n).padStart(2, "0");
    let index = 0;
    let timer: number | undefined;

    const activeDot = "w-6 bg-[var(--color-accent)]";
    const idleDot = "w-1.5 bg-[var(--color-border-strong)] hover:bg-[var(--color-fg-subtle)]";
    dots.forEach((d) => (d.className += " " + idleDot));

    // Fix the stage to the tallest quote so nothing clips or jumps.
    function sizeViewport() {
      let max = 0;
      for (const s of slides) max = Math.max(max, s.offsetHeight);
      if (max) viewport!.style.minHeight = max + "px";
    }

    function offsetFor(i: number) {
      let d = i - index;
      if (d > half) d -= total;
      if (d < -half) d += total;
      return d;
    }

    function render() {
      slides.forEach((s, i) => {
        const d = offsetFor(i);
        s.classList.remove("is-center", "is-left", "is-right", "is-far-left", "is-far-right");
        s.classList.add(
          d === 0 ? "is-center" : d === -1 ? "is-left" : d === 1 ? "is-right" : d < 0 ? "is-far-left" : "is-far-right",
        );
        s.setAttribute("aria-hidden", d === 0 ? "false" : "true");
      });
      dots.forEach((dot, i) => {
        const on = i === index;
        dot.className = dot.className.replace(activeDot, "").replace(idleDot, "").trim();
        dot.className += " " + (on ? activeDot : idleDot);
        dot.setAttribute("aria-selected", on ? "true" : "false");
      });
      if (counter) counter.textContent = `${pad(index + 1)} / ${pad(total)}`;
    }

    function goTo(i: number) {
      index = (i + total) % total;
      render();
    }
    const next = () => goTo(index + 1);
    const prev = () => goTo(index - 1);

    function stop() {
      if (timer) window.clearInterval(timer);
      timer = undefined;
    }
    function start() {
      stop();
      if (reduceMotion.matches || document.hidden) return;
      timer = window.setInterval(next, AUTOPLAY_MS);
    }
    function restart() {
      stop();
      start();
    }

    nextBtn?.addEventListener("click", () => { next(); restart(); });
    prevBtn?.addEventListener("click", () => { prev(); restart(); });
    dots.forEach((d, i) => d.addEventListener("click", () => { goTo(i); restart(); }));
    // Click a side card to bring it into focus.
    slides.forEach((s, i) => s.addEventListener("click", () => {
      if (offsetFor(i) !== 0) { goTo(i); restart(); }
    }));

    root.addEventListener("keydown", (e) => {
      if (e.key === "ArrowRight") { e.preventDefault(); next(); restart(); }
      else if (e.key === "ArrowLeft") { e.preventDefault(); prev(); restart(); }
    });

    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);
    root.addEventListener("focusin", stop);
    root.addEventListener("focusout", start);
    document.addEventListener("visibilitychange", () => (document.hidden ? stop() : start()));
    reduceMotion.addEventListener("change", restart);

    // Swipe.
    let downX: number | null = null;
    viewport.addEventListener("pointerdown", (e) => { downX = e.clientX; stop(); });
    viewport.addEventListener("pointerup", (e) => {
      if (downX === null) return;
      const dx = e.clientX - downX;
      if (Math.abs(dx) > SWIPE_THRESHOLD) (dx < 0 ? next : prev)();
      downX = null;
      start();
    });
    viewport.addEventListener("pointercancel", () => { downX = null; start(); });

    let resizeTimer: number | undefined;
    window.addEventListener("resize", () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(sizeViewport, 150);
    });
    if ((document as any).fonts?.ready) (document as any).fonts.ready.then(sizeViewport);

    sizeViewport();
    render();
    start();
  }

  document.querySelectorAll<HTMLElement>("[data-carousel]").forEach(initCarousel);
</script>
