---
import { testimonials as all } from "../data/testimonials";

interface Props {
  limit?: number;
  heading?: string;
  blurb?: string;
}

const {
  limit,
  heading = "In their words.",
  blurb = "Recommendations from LinkedIn — designers, engineers, and clients I've worked with.",
} = Astro.props;

const items = typeof limit === "number" ? all.slice(0, limit) : all;
const total = items.length;
const pad = (n: number) => String(n).padStart(2, "0");
---

<section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-16 md:py-20 border-t border-[var(--color-border)]">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10 md:mb-12" data-reveal>
    <div>
      <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-accent)]">
        Testimonials
      </span>
      <h2 class="mt-2 text-2xl md:text-4xl font-extrabold display" style="letter-spacing:-0.035em;">
        {heading}
      </h2>
    </div>
    <p class="text-sm md:text-[15px] text-[var(--color-fg-muted)] leading-relaxed max-w-sm md:text-right">
      {blurb}
    </p>
  </div>

  {total <= 1 ? (
    items.map((t) => (
      <figure class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-7 md:p-10 max-w-3xl">
        <blockquote class="text-lg md:text-2xl leading-relaxed text-[var(--color-fg)]">{t.quote}</blockquote>
        <figcaption class="mt-6 pt-5 border-t border-[var(--color-border)]">
          <div class="font-semibold text-[var(--color-fg)]">{t.name}</div>
          <div class="font-mono text-[11px] uppercase tracking-wider text-[var(--color-fg-subtle)] mt-1">
            {t.role}{t.relation ? ` · ${t.relation}` : ""}
          </div>
        </figcaption>
      </figure>
    ))
  ) : (
    <div
      data-carousel
      class="relative"
      role="region"
      aria-roledescription="carousel"
      aria-label="Testimonials"
      data-reveal
    >
      <div data-viewport class="overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] touch-pan-y">
        <div data-track class="flex transition-transform duration-[600ms] ease-[cubic-bezier(0.16,1,0.3,1)] motion-reduce:transition-none">
          {items.map((t, i) => (
            <figure
              data-slide
              class="min-w-full w-full shrink-0 p-7 md:p-12"
              role="group"
              aria-roledescription="slide"
              aria-label={`${i + 1} of ${total}`}
              aria-hidden={i === 0 ? "false" : "true"}
            >
              <div class="max-w-3xl mx-auto flex flex-col">
                <svg class="size-8 text-[var(--color-accent)] opacity-30 mb-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M9.5 6C6.5 6 4 8.5 4 11.5V18h6v-6H7c0-1.7 1.1-3 2.5-3V6Zm10 0c-3 0-5.5 2.5-5.5 5.5V18h6v-6h-3c0-1.7 1.1-3 2.5-3V6Z" />
                </svg>
                <blockquote class="text-lg md:text-2xl lg:text-[28px] leading-[1.45] text-[var(--color-fg)] font-medium tracking-[-0.01em]">
                  {t.quote}
                </blockquote>
                <figcaption class="mt-7 pt-5 border-t border-[var(--color-border)]">
                  <div class="font-semibold text-[var(--color-fg)] text-[15px] md:text-base">{t.name}</div>
                  <div class="font-mono text-[11px] uppercase tracking-wider text-[var(--color-fg-subtle)] mt-1">
                    {t.role}{t.relation ? ` · ${t.relation}` : ""}
                  </div>
                  {t.translated && (
                    <div class="font-mono text-[10px] text-[var(--color-fg-subtle)] opacity-70 mt-1.5">
                      Translated from Portuguese
                    </div>
                  )}
                </figcaption>
              </div>
            </figure>
          ))}
        </div>
      </div>

      <!-- Controls -->
      <div class="mt-6 flex items-center justify-between gap-6">
        <div class="flex items-center gap-2">
          <button
            data-prev
            type="button"
            aria-label="Previous testimonial"
            class="grid place-items-center size-10 rounded-full border border-[var(--color-border-strong)] text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:border-[var(--color-fg)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)] transition-colors"
          >
            <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6" /></svg>
          </button>
          <button
            data-next
            type="button"
            aria-label="Next testimonial"
            class="grid place-items-center size-10 rounded-full border border-[var(--color-border-strong)] text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:border-[var(--color-fg)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)] transition-colors"
          >
            <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6" /></svg>
          </button>
        </div>

        <div class="flex items-center gap-4">
          <div data-dots class="flex items-center gap-1.5" role="tablist" aria-label="Choose testimonial">
            {items.map((_, i) => (
              <button
                data-dot
                type="button"
                role="tab"
                aria-label={`Go to testimonial ${i + 1}`}
                aria-selected={i === 0 ? "true" : "false"}
                class="h-1.5 rounded-full transition-all duration-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
              ></button>
            ))}
          </div>
          <span data-counter class="font-mono text-[11px] tracking-wider text-[var(--color-fg-subtle)] tabular-nums">
            {pad(1)} / {pad(total)}
          </span>
        </div>
      </div>
    </div>
  )}
</section>

<script>
  const AUTOPLAY_MS = 6000;
  const SWIPE_THRESHOLD = 40;
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  function initCarousel(root: HTMLElement) {
    const track = root.querySelector<HTMLElement>("[data-track]");
    const viewport = root.querySelector<HTMLElement>("[data-viewport]");
    const slides = Array.from(root.querySelectorAll<HTMLElement>("[data-slide]"));
    const dots = Array.from(root.querySelectorAll<HTMLElement>("[data-dot]"));
    const counter = root.querySelector<HTMLElement>("[data-counter]");
    const prevBtn = root.querySelector<HTMLElement>("[data-prev]");
    const nextBtn = root.querySelector<HTMLElement>("[data-next]");
    if (!track || !viewport || slides.length < 2) return;

    const total = slides.length;
    const pad = (n: number) => String(n).padStart(2, "0");
    let index = 0;
    let timer: number | undefined;

    const activeDot = "w-6 bg-[var(--color-accent)]";
    const idleDot = "w-1.5 bg-[var(--color-border-strong)] hover:bg-[var(--color-fg-subtle)]";
    dots.forEach((d) => (d.className += " " + idleDot));

    function render() {
      track!.style.transform = `translateX(-${index * 100}%)`;
      slides.forEach((s, i) => s.setAttribute("aria-hidden", i === index ? "false" : "true"));
      dots.forEach((d, i) => {
        const on = i === index;
        d.className = d.className.replace(activeDot, "").replace(idleDot, "").trim();
        d.className += " " + (on ? activeDot : idleDot);
        d.setAttribute("aria-selected", on ? "true" : "false");
      });
      if (counter) counter.textContent = `${pad(index + 1)} / ${pad(total)}`;
    }

    function goTo(i: number) {
      index = (i + total) % total;
      render();
    }
    const next = () => goTo(index + 1);
    const prev = () => goTo(index - 1);

    // Autoplay — paused on hover/focus, tab-hidden, and reduced-motion.
    function stop() {
      if (timer) window.clearInterval(timer);
      timer = undefined;
    }
    function start() {
      stop();
      if (reduceMotion.matches || document.hidden) return;
      timer = window.setInterval(next, AUTOPLAY_MS);
    }
    function restart() {
      stop();
      start();
    }

    nextBtn?.addEventListener("click", () => { next(); restart(); });
    prevBtn?.addEventListener("click", () => { prev(); restart(); });
    dots.forEach((d, i) => d.addEventListener("click", () => { goTo(i); restart(); }));

    root.addEventListener("keydown", (e) => {
      if (e.key === "ArrowRight") { e.preventDefault(); next(); restart(); }
      else if (e.key === "ArrowLeft") { e.preventDefault(); prev(); restart(); }
    });

    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);
    root.addEventListener("focusin", stop);
    root.addEventListener("focusout", start);
    document.addEventListener("visibilitychange", () => (document.hidden ? stop() : start()));
    reduceMotion.addEventListener("change", restart);

    // Swipe (touch / pointer).
    let downX: number | null = null;
    viewport.addEventListener("pointerdown", (e) => { downX = e.clientX; stop(); });
    viewport.addEventListener("pointerup", (e) => {
      if (downX === null) return;
      const dx = e.clientX - downX;
      if (Math.abs(dx) > SWIPE_THRESHOLD) (dx < 0 ? next : prev)();
      downX = null;
      start();
    });
    viewport.addEventListener("pointercancel", () => { downX = null; start(); });

    render();
    start();
  }

  document.querySelectorAll<HTMLElement>("[data-carousel]").forEach(initCarousel);
</script>
