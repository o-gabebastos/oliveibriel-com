---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Testimonials from "../Testimonials.astro";
import { getLocale } from "../../i18n/config";
import { useCopy } from "../../i18n/copy";
import { getCareer } from "../../i18n/content";

const locale = getLocale(Astro.currentLocale);
const c = useCopy(locale);
const t = c.about;
const careerTimeline = getCareer(locale);
---

<BaseLayout title={c.seo.aboutTitle} description={c.seo.aboutDescription}>
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-12">
    <div class="grid md:grid-cols-[1fr_320px] gap-12 items-start">
      <div>
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">
          {t.eyebrow}
        </span>
        <h1
          class="mt-3 text-4xl md:text-6xl font-extrabold leading-[1.02]"
          style="letter-spacing: -0.045em;"
        >
          {t.h1a}<br />
          <span class="text-[var(--color-fg-muted)]">{t.h1b}</span>
        </h1>
        <p class="mt-6 text-lg text-[var(--color-fg-muted)] leading-relaxed max-w-2xl" set:html={t.introHtml}></p>
        <p class="mt-4 text-lg text-[var(--color-fg-muted)] leading-relaxed max-w-2xl">
          {t.para2}
        </p>
      </div>
      <aside class="md:sticky md:top-20">
        <div class="mb-4 overflow-hidden rounded-xl border border-[var(--color-border)] aspect-square">
          <img
            src="/gabriel-oliveira.jpg"
            alt="Gabriel Oliveira"
            width="800"
            height="800"
            loading="eager"
            class="w-full h-full object-cover grayscale"
          />
        </div>
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-6">
          <div class="flex items-center gap-2.5 mb-5 pb-5 border-b border-[var(--color-border)]">
            <span class="relative flex size-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--color-success)] opacity-60"></span>
              <span class="relative inline-flex rounded-full size-2 bg-[var(--color-success)]"></span>
            </span>
            <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-muted)]">
              {t.available}
            </span>
          </div>
          <dl class="grid gap-4 font-mono text-[11px] uppercase tracking-wider text-[var(--color-fg-subtle)]">
            <div class="flex flex-col gap-1">
              <dt>{t.role}</dt>
              <dd class="text-[var(--color-fg)] normal-case tracking-normal text-sm font-sans">{t.roleVal}</dd>
            </div>
            <div class="flex flex-col gap-1">
              <dt>{t.focus}</dt>
              <dd class="text-[var(--color-fg)] normal-case tracking-normal text-sm font-sans">{t.focusVal}</dd>
            </div>
            <div class="flex flex-col gap-1">
              <dt>{t.basedIn}</dt>
              <dd class="text-[var(--color-fg)] normal-case tracking-normal text-sm font-sans">{t.basedInVal}</dd>
            </div>
            <div class="flex flex-col gap-1">
              <dt>{t.currently}</dt>
              <dd class="text-[var(--color-fg)] normal-case tracking-normal text-sm font-sans">{t.currentlyVal}</dd>
            </div>
            <div class="flex flex-col gap-1">
              <dt>{t.languages}</dt>
              <dd class="text-[var(--color-fg)] normal-case tracking-normal text-sm font-sans">{t.languagesVal}</dd>
            </div>
          </dl>
        </div>
        <div class="mt-4 flex flex-col gap-2 font-mono text-[11px]">
          <a
            href="/gabriel-oliveira-cv.pdf"
            class="px-4 py-2.5 rounded-md bg-[var(--color-fg)] hover:bg-[var(--color-accent)] text-white flex items-center justify-between gap-2 transition-colors"
            download
          >
            <span class="uppercase tracking-wider text-[10px] opacity-80">{t.resumeCv}</span>
            <span class="font-sans text-sm inline-flex items-center gap-1.5">
              {t.downloadPdf}
              <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            </span>
          </a>
          <a href="https://www.linkedin.com/in/oliveibriel" target="_blank" rel="noopener noreferrer" class="px-4 py-2.5 rounded-md border border-[var(--color-border)] hover:border-[var(--color-fg)] flex items-center justify-between gap-2 text-[var(--color-fg)] transition-colors">
            <span class="uppercase tracking-wider text-[10px] text-[var(--color-fg-subtle)]">{t.linkedin}</span>
            <span class="font-sans text-sm">/in/oliveibriel ↗</span>
          </a>
          <a href="mailto:gabriel@oliveibriel.com" class="px-4 py-2.5 rounded-md border border-[var(--color-border)] hover:border-[var(--color-fg)] flex items-center justify-between gap-2 text-[var(--color-fg)] transition-colors">
            <span class="uppercase tracking-wider text-[10px] text-[var(--color-fg-subtle)]">{t.email}</span>
            <span class="font-sans text-sm">gabriel@oliveibriel.com</span>
          </a>
        </div>
      </aside>
    </div>
  </section>

  <!-- Journey -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-16 border-t border-[var(--color-border)]">
    <div class="grid md:grid-cols-[280px_1fr] gap-10">
      <div>
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">{t.journeyEyebrow}</span>
        <h2 class="mt-2 text-2xl md:text-3xl font-bold tracking-tight" style="letter-spacing: -0.03em;">
          {t.journeyTitle}
        </h2>
      </div>
      <div class="prose-content max-w-2xl flex flex-col gap-5 text-[var(--color-fg-muted)] leading-relaxed">
        <p>{t.journeyP1Html}</p>
        <p>{t.journeyP2Html}</p>
      </div>
    </div>
  </section>

  <!-- Career timeline -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-16 border-t border-[var(--color-border)]">
    <div class="grid md:grid-cols-[280px_1fr] gap-10">
      <div>
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">{t.experienceEyebrow}</span>
        <h2 class="mt-2 text-2xl md:text-3xl font-bold tracking-tight" style="letter-spacing: -0.03em;">
          {t.experienceTitle}
        </h2>
        <p class="mt-3 text-sm text-[var(--color-fg-muted)] leading-relaxed">
          {t.experienceSubPrefix}
          <a href="https://www.linkedin.com/in/oliveibriel" target="_blank" rel="noopener noreferrer" class="link-underline text-[var(--color-fg)]">LinkedIn</a>.
        </p>
      </div>
      <ol class="flex flex-col">
        {careerTimeline.map((item, i) => (
          <li class={`grid grid-cols-[1fr] sm:grid-cols-[10rem_1fr] gap-2 sm:gap-8 py-5 ${i === 0 ? "" : "border-t border-[var(--color-border)]"}`}>
            <div class="font-mono text-[11px] uppercase tracking-wider text-[var(--color-fg-subtle)] tabular pt-0.5">
              {item.range}
            </div>
            <div>
              <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5">
                <span class="text-base md:text-lg font-semibold text-[var(--color-fg)]">{item.org}</span>
                <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">·</span>
                <span class="text-sm text-[var(--color-fg-muted)]">{item.role}</span>
              </div>
              <p class="mt-1.5 text-sm text-[var(--color-fg-muted)] leading-relaxed max-w-2xl">
                {item.summary}
              </p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Skills -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-16 border-t border-[var(--color-border)]">
    <div class="grid md:grid-cols-[280px_1fr] gap-10">
      <div>
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">{t.skillsEyebrow}</span>
        <h2 class="mt-2 text-2xl md:text-3xl font-bold tracking-tight" style="letter-spacing: -0.03em;">
          {t.skillsTitle}
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-x-8 gap-y-6 max-w-3xl">
        <div>
          <h3 class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)] mb-3">{t.catDesign}</h3>
          <ul class="flex flex-wrap gap-2">
            {t.skillsDesign.map((skill) => (
              <li class="px-2.5 py-1 rounded-md border border-[var(--color-border)] text-xs text-[var(--color-fg-muted)]">{skill}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)] mb-3">{t.catTools}</h3>
          <ul class="flex flex-wrap gap-2">
            {t.skillsTools.map((skill) => (
              <li class="px-2.5 py-1 rounded-md border border-[var(--color-border)] text-xs text-[var(--color-fg-muted)]">{skill}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)] mb-3">{t.catAi}</h3>
          <ul class="flex flex-wrap gap-2">
            {t.skillsAi.map((skill) => (
              <li class="px-2.5 py-1 rounded-md border border-[var(--color-border)] text-xs text-[var(--color-fg-muted)]">{skill}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)] mb-3">{t.catDomains}</h3>
          <ul class="flex flex-wrap gap-2">
            {t.skillsDomains.map((skill) => (
              <li class="px-2.5 py-1 rounded-md border border-[var(--color-border)] text-xs text-[var(--color-fg-muted)]">{skill}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <Testimonials />

  <!-- Outside of work -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-16 border-t border-[var(--color-border)]">
    <div class="grid md:grid-cols-[280px_1fr] gap-10">
      <div>
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">{t.outsideEyebrow}</span>
        <h2 class="mt-2 text-2xl md:text-3xl font-bold tracking-tight" style="letter-spacing: -0.03em;">
          {t.outsideTitle}
        </h2>
      </div>
      <div class="max-w-2xl text-[var(--color-fg-muted)] leading-relaxed flex flex-col gap-4">
        <p>{t.outsideP1}</p>
        <p>{t.outsideP2}</p>
        <p>{t.outsideP3}</p>
      </div>
    </div>
  </section>

  <!-- Elsewhere -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-16 border-t border-[var(--color-border)]">
    <div class="grid md:grid-cols-[280px_1fr] gap-10">
      <div>
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">{t.elsewhereEyebrow}</span>
        <h2 class="mt-2 text-2xl md:text-3xl font-bold tracking-tight" style="letter-spacing: -0.03em;">
          {t.elsewhereTitle}
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-3 max-w-2xl">
        <a href="https://www.linkedin.com/in/oliveibriel" target="_blank" rel="noopener noreferrer" class="border border-[var(--color-border)] rounded-lg p-5 hover:border-[var(--color-fg)] transition-colors">
          <div class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">LinkedIn ↗</div>
          <div class="mt-2 font-medium text-[var(--color-fg)]">/in/oliveibriel</div>
          <div class="text-sm text-[var(--color-fg-muted)] mt-1">{t.elsewhereLinkedinNote}</div>
        </a>
        <a href="mailto:gabriel@oliveibriel.com" class="border border-[var(--color-border)] rounded-lg p-5 hover:border-[var(--color-fg)] transition-colors">
          <div class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">{t.email}</div>
          <div class="mt-2 font-medium text-[var(--color-fg)]">gabriel@oliveibriel.com</div>
          <div class="text-sm text-[var(--color-fg-muted)] mt-1">{t.elsewhereEmailNote}</div>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
