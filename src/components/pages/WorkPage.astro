---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../ProjectCard.astro";
import { getLocale, localePath } from "../../i18n/config";
import { useCopy } from "../../i18n/copy";
import { getProjects } from "../../i18n/content";

const locale = getLocale(Astro.currentLocale);
const c = useCopy(locale);
const t = c.work;

const projects = getProjects(locale);
const bySlug = (slug: string) => projects.find((p) => p.slug === slug);

// Structure (which project sits in which group) is locale-independent; the
// eyebrow/title/blurb come from the copy dictionary.
const groupSlugs = [
  ["iris-v3", "netzsch-design-system", "norius", "netzsch-customer-portal", "digital-reports", "iris-design-system"],
  ["nerida", "techcolab", "garmin-coach", "mosey"],
  ["myct-connecticut", "superdigital", "dell-expert-network", "eye", "gan-dath"],
];
const groups = t.groups.map((g, i) => ({
  ...g,
  items: groupSlugs[i].map(bySlug).filter(Boolean),
}));

const yearSpan = `${Math.min(...projects.map((p) => parseInt(p.year)))} → ${Math.max(...projects.map((p) => parseInt(p.year)))}`;
---

<BaseLayout title={c.seo.workTitle} description={c.seo.workDescription}>
  <!-- Page hero -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 pt-14 md:pt-20 pb-12 md:pb-16">
    <span class="font-mono text-[11px] uppercase tracking-wider text-[var(--color-fg-subtle)]">
      {t.heroEyebrowPrefix} · {projects.length} {t.heroEyebrowProjects} · {yearSpan}
    </span>
    <h1
      class="mt-3 text-4xl md:text-6xl font-extrabold display"
      style="letter-spacing:-0.045em;"
    >
      {t.heroH1a}<br />{t.heroH1b}
    </h1>
    <p class="mt-5 text-lg text-[var(--color-fg-muted)] max-w-2xl leading-relaxed">
      {t.heroPara}
    </p>
  </section>

  <!-- Grouped work -->
  {groups.map((group) => (
    <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-12 md:py-16 border-t border-[var(--color-border)]">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8 md:mb-10" data-reveal>
        <div>
          <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-accent)]">
            {group.eyebrow}
          </span>
          <h2 class="mt-2 text-2xl md:text-4xl font-extrabold display" style="letter-spacing:-0.035em;">
            {group.title}
          </h2>
        </div>
        <p class="text-sm md:text-[15px] text-[var(--color-fg-muted)] leading-relaxed max-w-sm md:text-right">
          {group.blurb}
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
        {group.items.map((project, i) => (
          <ProjectCard project={project} index={i} size="normal" />
        ))}
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-20 border-t border-[var(--color-border)]">
    <div class="flex flex-col gap-5 max-w-2xl">
      <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">
        {t.ctaEyebrow}
      </span>
      <h2 class="text-3xl md:text-5xl font-extrabold display" style="letter-spacing:-0.045em;">
        {t.ctaTitle}
      </h2>
      <a
        href="mailto:gabriel@oliveibriel.com"
        class="self-start inline-flex items-center gap-2 px-5 py-3 rounded-md bg-[var(--color-fg)] hover:bg-[var(--color-accent)] text-white text-sm font-medium transition-colors mt-2"
      >
        gabriel@oliveibriel.com
        <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 17 17 7M7 7h10v10"/>
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
